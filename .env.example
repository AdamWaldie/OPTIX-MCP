# Your OPTIX API key (required)
# Create one in OPTIX Settings → API Keys
OPTIX_API_KEY=optix_your_api_key_here

# Base URL of the OPTIX instance (optional — defaults to production)
# Uncomment and override only for local development or self-hosted OPTIX instances
# OPTIX_API_URL=https://optixthreatintelligence.co.uk

# Port the MCP server listens on (default: 8090)
MCP_PORT=8090

# Host the MCP server binds to (default: 0.0.0.0)
MCP_HOST=0.0.0.0

# Seconds before upstream OPTIX calls time out (default: 30)
OPTIX_REQUEST_TIMEOUT=30
